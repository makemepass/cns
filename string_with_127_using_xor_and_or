#include <stdio.h>
#include <string.h>
int main()
{
    char str[] = "Hello World";
    char xorStr[20], andStr[20], orStr[20];
    int i, len;
    len = strlen(str);
    printf("Original String : %s\n", str);
    printf("\nXOR with 127:\n");
    for(i = 0; i < len; i++)
    {
        xorStr[i] = str[i] ^ 127;
        printf("%c", xorStr[i]);
    }
    xorStr[len] = '\0';
    printf("\n\nAND with 127:\n");
    for(i = 0; i < len; i++)
    {
        andStr[i] = str[i] & 127;
        printf("%c", andStr[i]);
    }
    andStr[len] = '\0';
    printf("\n\nOR with 127:\n");
    for(i = 0; i < len; i++)
    {
        orStr[i] = str[i] | 127;
        printf("%c", orStr[i]);
    }
    orStr[len] = '\0';
    printf("\n");
    return 0;
}
