#include <stdio.h>
#include <string.h>
int main()
{
    char str[] = "Hello World";
    int i, len;
    len = strlen(str);
    printf("Encrypted:\n");
    for(i = 0; i < len; i++)
    {
        str[i] = str[i] ^ 127;
        printf("%c", str[i]);
    }
    printf("\n");
    printf("Decrypted:\n");
    for(i = 0; i < len; i++)
    {
        str[i] = str[i] ^ 127;
        printf("%c", str[i]);
    }
    printf("\n");
    return 0;
}
